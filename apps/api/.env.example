# Local development (Docker Postgres — see docker-compose.yml)
DATABASE_URL="postgresql://agbms:agbms123@localhost:5432/agbms"

# Auth
JWT_SECRET="change-me-in-production"
REFRESH_TOKEN_SECRET="change-me-in-production-too"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Comma-separated frontend origins (Vercel + local)
CORS_ORIGIN="http://localhost:5173"

# File uploads (ephemeral on Render free tier — use persistent disk path in production)
UPLOAD_DIR="./uploads"

# Render sets PORT automatically
PORT=3001
